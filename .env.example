# Supabase (required — get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App - For local dev use http://localhost:3000 (or your port)
# IMPORTANT: In Vercel, set NEXT_PUBLIC_SITE_URL to your production URL
# (e.g., https://your-app.vercel.app) in the Vercel dashboard under
# Project Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=http://localhost:3000
